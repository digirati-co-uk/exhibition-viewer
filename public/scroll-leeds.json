_044.tif/full/817,1024/0/default.jpg","type":"Image","format":"image/jpeg","height":1024,"width":817,"service":[{"@context":"http://iiif.io/api/image/2/context.json","@id":"https://iiif.library.leeds.ac.uk/image/v2/bvfhzdgw_objects_LUA-PUB-002-GRY-40_044.tif","@type":"ImageService2","profile":"http://iiif.io/api/image/2/level2.json","width":3178,"height":3985},{"@context":"http://iiif.io/api/image/3/context.json","id":"https://iiif.library.leeds.ac.uk/image/bvfhzdgw_objects_LUA-PUB-002-GRY-40_044.tif","type":"ImageService3","profile":"level2","width":3178,"height":3985}]}}]}],"annotations":[{"id":"https://presentation-api.dlcs.digirati.io/177/manifests/6wjo2gg32ucis3rszlcs0qa/canvas/uu11c4xu8d-mqz7e8ib/AnnotationPage/5yu6esdpxqs-mqz7e8k1","type":"AnnotationPage","items":[{"id":"https://presentation-api.dlcs.digirati.io/177/manifests/6wjo2gg32ucis3rszlcs0qa/canvas/uu11c4xu8d-mqz7e8ib/AnnotationPage/5yu6esdpxqs-mqz7e8k1/annotation/1wpc2x2idqr-mqz8xarm","type":"Annotation","motivation":"tagging","target":{"id":"https://presentation-api.dlcs.digirati.io/177/manifests/6wjo2gg32ucis3rszlcs0qa/canvas/uu11c4xu8d-mqz7e8ib/annotation-page/2e5jx8ju5pg-mqz7e8ib/Annotation/2e1l003yjdu-mqz7e8k1","type":"Annotation"},"body":[]},{"id":"https://presentation-api.dlcs.digirati.io/177/manifests/6wjo2gg32ucis3rszlcs0qa/canvas/uu11c4xu8d-mqz7e8ib/AnnotationPage/5yu6esdpxqs-mqz7e8k1/annotation/b4gev1478yk-mqz8zug9","type":"Annotation","motivation":"tagging","target":"undefined#xywh=432,607,172,102","body":{"id":"https://presentation-api.dlcs.digirati.io/177/manifests/6wjo2gg32ucis3rszlcs0qa/canvas/uu11c4xu8d-mqz7e8ib/AnnotationPage/5yu6esdpxqs-mqz7e8k1/annotation/b4gev1478yk-mqz8zug9/html/en/ztlxorxk69-mqz8zug9","type":"TextualBody","format":"text/html","language":"en","value":"<h2 id=\"the-school-was-so-popular-with-lots-of-students-enrolling-that-they-had-to-move-to-a-house-at-1-east-parade-leeds-near-to-the-leeds-general-infirmary-by-1863-the-medical-school-had-60-students-and-the-east-parade-site-was-too-small-two-years-later-a-new-purpose-built-school-was-constructed-in-park-street-which-you-can-see-in-this-photograph-much-nearer-to-the-hospital-it-was-easier-for-the-medical-students-to-work-in\">The school was so popular, with lots of students enrolling, that they had to move to a house at 1 East Parade, Leeds near to the Leeds General Infirmary. By 1863 the Medical School had 60 students and the East Parade site was too small. Two years later a new purpose-built school was constructed in Park Street, which you can see in this photograph. Much nearer to the hospital, it was easier for the medical students to work in.</h2>"}}]}]},{"id":"https://presentation-api.dlcs.digirati.io/177/manifests/6wjo2gg32ucis3rszlcs0qa/canvas/kbpyt8o046-mqz9pwea","type":"Canvas","height":1584,"width":1909,"behavior":["image","w-12","h-10","cover"],"label":{"en":["Photograph of the Leeds School of Medicine in The Gryphon: Second Series, Volume 4, Ten Pictures, 1923/1923"]},"summary":{"en":["<p>Test</p>"]},"items":[{"id":"https://presentation-api.dlcs.digirati.io/177/manifests/6wjo2gg32ucis3rszlcs0qa/canvas/kbpyt8o046-mqz9pwea/AnnotationPage/mn3jchccdrs-mqz9pwj2","type":"AnnotationPage","items":[{"id":"https://presentation-api.dlcs.digirati.io/177/manifests/6wjo2gg32ucis3rszlcs0qa/canvas/kbpyt8o046-mqz9pwea/annotation-page/9wdpcys2r9-mqz9pwea/Annotation/xsix9wfgcg-mqz9pwj1","type":"Annotation","motivation":"painting","summary":{"en":["Student numbers continued to grow and in 1891 construction began on another new Medical School at Thoresby Place, right next to the Leeds General Infirmary.  It was completed in 1894. Could these be medical students on their way to a lecture?  "]},"target":"https://presentation-api.dlcs.digirati.io/177/manifests/6wjo2gg32ucis3rszlcs0qa/canvas/kbpyt8o046-mqz9pwea","body":{"id":"https://iiif.library.leeds.ac.uk/canvases/t1dg8jd3_objects_LUA-PUB-002-GRY-154_012.tif/annotations/11/SpecificResource/z534kqce2uc-mqz9pwj1","type":"SpecificResou