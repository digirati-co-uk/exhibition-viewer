ests/6wjo2gg32ucis3rszlcs0qa/canvas/9myts9nvbcp-mqzaymck","body":{"id":"https://iiif.library.leeds.ac.uk/image/bvfhzdgw_objects_LUA-PUB-002-GRY-40_047.tif/full/817,1024/0/default.jpg","type":"Image","format":"image/jpeg","height":1024,"width":817,"service":[{"@context":"http://iiif.io/api/image/2/context.json","@id":"https://iiif.library.leeds.ac.uk/image/v2/bvfhzdgw_objects_LUA-PUB-002-GRY-40_047.tif","@type":"ImageService2","profile":"http://iiif.io/api/image/2/level2.json","width":3178,"height":3985},{"@context":"http://iiif.io/api/image/3/context.json","id":"https://iiif.library.leeds.ac.uk/image/bvfhzdgw_objects_LUA-PUB-002-GRY-40_047.tif","type":"ImageService3","profile":"level2","width":3178,"height":3985}]}}]}],"annotations":[{"id":"https://presentation-api.dlcs.digirati.io/177/manifests/6wjo2gg32ucis3rszlcs0qa/canvas/9myts9nvbcp-mqzaymck/AnnotationPage/9t6tulq6alp-mqzaymic","type":"AnnotationPage","items":[{"id":"https://presentation-api.dlcs.digirati.io/177/manifests/6wjo2gg32ucis3rszlcs0qa/canvas/9myts9nvbcp-mqzaymck/AnnotationPage/9t6tulq6alp-mqzaymic/annotation/95guimfrvsf-mqzaza2f","type":"Annotation","motivation":"tagging","target":{"id":"https://presentation-api.dlcs.digirati.io/177/manifests/6wjo2gg32ucis3rszlcs0qa/canvas/9myts9nvbcp-mqzaymck/annotation-page/y1a4q1mwzie-mqzaymck/Annotation/ovefel0hchf-mqzaymic","type":"Annotation"},"body":[]},{"id":"https://presentation-api.dlcs.digirati.io/177/manifests/6wjo2gg32ucis3rszlcs0qa/canvas/9myts9nvbcp-mqzaymck/AnnotationPage/9t6tulq6alp-mqzaymic/annotation/pj04vbqhwbb-mqzazy2s","type":"Annotation","motivation":"tagging","target":"undefined#xywh=171,308,246,150","body":{"id":"https://presentation-api.dlcs.digirati.io/177/manifests/6wjo2gg32ucis3rszlcs0qa/canvas/9myts9nvbcp-mqzaymck/AnnotationPage/9t6tulq6alp-mqzaymic/annotation/pj04vbqhwbb-mqzazy2s/html/en/mes99ettsea-mqzazy2s","type":"TextualBody","format":"text/html","language":"en","value":"<p>In 1884 the&nbsp;Leeds School of Medicine&nbsp;joined with the&nbsp;Yorkshire College.&nbsp;Over the next ten years&nbsp;more new&nbsp;buildings&nbsp;opened, such as the Great Hall.&nbsp;Medical teaching was based at the Leeds School of Medicine and teaching&nbsp; in all the other subjects moved to College Road.</p>"}},{"id":"https://presentation-api.dlcs.digirati.io/177/manifests/6wjo2gg32ucis3rszlcs0qa/canvas/9myts9nvbcp-mqzaymck/AnnotationPage/9t6tulq6alp-mqzaymic/annotation/3tapgk57pum-mqzb1a8z","type":"Annotation","motivation":"tagging","target":"undefined#xywh=269,539,293,184","body":{"id":"https://presentation-api.dlcs.digirati.io/177/manifests/6wjo2gg32ucis3rszlcs0qa/canvas/9myts9nvbcp-mqzaymck/AnnotationPage/9t6tulq6alp-mqzaymic/annotation/3tapgk57pum-mqzb1a8z/html/en/oc1yl3m4p4-mqzb1a8z","type":"TextualBody","format":"text/html","language":"en","value":"<p>In 1887 The Yorkshire College entered Victoria University, which was a University of the North of England based in Manchester. Other Northern colleges could join, but remain independent. Other member colleges were Owens College Manchester and University College Liverpool.</p>"}}]}]},{"id":"https://presentation-api.dlcs.digirati.io/177/manifests/6wjo2gg32ucis3rszlcs0qa/canvas/p1az9n1pby-mqzb5gqf","type":"Canvas","height":1000,"width":1000,"behavior":["info","w-12"],"label":{"en":["Credits: Story"]},"items":[{"id":"https://presentation-api.dlcs.digirati.io/177/manifests/6wjo2gg32ucis3rszlcs0qa/canvas/p1az9n1pby-mqzb5gqf/annotation-page/nzor5goii6g-mqzb5gqf","type":"AnnotationPage","items":[{"id":"https://presentation-api.dlcs.digirati.io/177/manifests/6wjo2gg32ucis3rszlcs0qa/canvas/p1az9n1pby-mqzb5gqf/annotation/9i31ezownp7-mqzb5gqf","type":"Annotation","motivation":"painting","target":"https://presentation-api.dlcs.digirati.io/177/manifests/6wjo2gg32ucis3rszlcs0qa/canvas/p1az9n1pby-mqzb5gqf","body":{"id":"https://presentation-api.dlcs.digirati.io/177/manifests/6wjo2gg32ucis3rszlcs0qa/canvas/p1az9n1pby-mqzb5gqf/annotation/9i31ezownp7-mqzb5gqf/html/en/000lxdr8577vlh-mqzb5gqf","type":"TextualBody","format":"text/html","language":"en","value":"<p>The items in this exhibition are from the&nbsp;<a href=\"https://library.leeds.ac.uk/special-collections/collection/715/university_archive_collection\" rel=\"noopener noreferrer nofollow\">University&nbsp;of&nbsp;Leeds&nbsp;Archive</a>&nbsp;which&nbsp;preserves the records of the University of Leeds and its predecessors, giving&nbsp;us an insight into&nbsp;past&nbsp;University life.&nbsp;&nbsp;<br>&nbsp;<br>Learn more about the history of the university on our <a href=\"https://www.leeds.ac.uk/info/5000/about/133/heritage\" rel=\"noopener noreferrer nofollow\">website&nbsp;</a><br><br>The University of Leeds and predecessor&nbsp;student newspapers&nbsp;have been fully digitised. Search the newspapers&nbsp;<a href=\"http://digital.library.leeds.ac.uk/view/newspapers/\" rel=\"noopener noreferrer nofollow\">here&nbsp;</a>&nbsp;<br><br>See more&nbsp;highlights&nbsp;from our student newspapers&nbsp;here&nbsp;&nbsp;&nbsp;</p><p>Credits: All media</p><p>Leeds University Library Galleries<br></p>"}}]}],"annotations":[{"id":"https://presentation-api.dlcs.digirati.io/177/manifests/6wjo2gg32ucis3rszlcs0qa/canvas/p1az9n1pby-mqzb5gqf/annotation-page/sb921zg1yg-mqzb5gqf","type":"AnnotationPage","items":[{"id":"https://presentation-api.dlcs.digirati.io/177/manifests/6wjo2gg32ucis3rszlcs0qa/canvas/p1az9n1pby-mqzb5gqf/annotation/jfo0ynzu6ti-mqzb5gqg","type":"Annotation","motivation":"tagging","target":"https://presentation-api.dlcs.digirati.io/177/manifests/6wjo2gg32ucis3rszlcs0qa/canvas/p1az9n1pby-mqzb5gqf","body":{"id":"https://presentation-api.dlcs.digirati.io/177/manifests/6wjo2gg32ucis3rszlcs0qa/canvas/p1az9n1pby-mqzb5gqf/annotation/jfo0ynzu6ti-mqzb5gqg/html/en/279rdloy4kn-mqzb5gqg","type":"TextualBody","format":"text/html","language":"en","value":"<p></p>"}}]}]}]}
